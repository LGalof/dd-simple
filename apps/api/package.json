{
  "name": "@dd-simple/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node ../../node_modules/tsx/dist/cli.mjs src/index.ts",
    "build": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "prisma:generate": "node ../../node_modules/prisma/build/index.js generate",
    "prisma:migrate": "node ../../node_modules/prisma/build/index.js migrate dev",
    "prisma:studio": "node ../../node_modules/prisma/build/index.js studio",
    "prisma:seed": "node ../../node_modules/tsx/dist/cli.mjs prisma/seed.ts",
    "seed:demo": "node ../../node_modules/tsx/dist/cli.mjs prisma/seed-local-demo.ts"
  },

  "dependencies": {
    "@prisma/client": "^6.8.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.9.0",
    "prisma": "^6.8.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "prisma": {
    "seed": "node ../../node_modules/tsx/dist/cli.mjs prisma/seed.ts"
  }
}
