generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String      @id @default(uuid()) @db.Uuid
  email       String      @unique
  displayName String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  characters  Character[]
}

model Character {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @db.Uuid

  name         String
  level        Int      @default(1)
  avatarUrl    String?

  speciesId    String?  @db.Uuid
  backgroundId String?  @db.Uuid
  classId      String?  @db.Uuid

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  species      SpeciesDefinition?    @relation(fields: [speciesId], references: [id])
  background   BackgroundDefinition? @relation(fields: [backgroundId], references: [id])
  class        ClassDefinition?      @relation(fields: [classId], references: [id])

  abilityScores     CharacterAbilityScores?
  sheetStats        CharacterSheetStats?
  featureSelections CharacterFeatureSelection[]
}

model CharacterAbilityScores {
  id           String @id @default(uuid()) @db.Uuid
  characterId  String @unique @db.Uuid

  strength     Int    @default(10)
  dexterity    Int    @default(10)
  constitution Int    @default(10)
  intelligence Int    @default(10)
  wisdom       Int    @default(10)
  charisma     Int    @default(10)

  character    Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

model CharacterSheetStats {
  id                String @id @default(uuid()) @db.Uuid
  characterId       String @unique @db.Uuid

  maxHp             Int    @default(10)
  currentHp         Int    @default(10)
  temporaryHp       Int    @default(0)

  armorClass        Int    @default(10)
  initiative        Int    @default(0)
  speed             Int    @default(30)
  proficiencyBonus  Int    @default(2)

  character         Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

model ClassDefinition {
  id          String @id @default(uuid()) @db.Uuid
  name        String @unique
  description String?

  features    ClassFeatureDefinition[]
  characters  Character[]
}

model SpeciesDefinition {
  id          String @id @default(uuid()) @db.Uuid
  name        String @unique
  description String?
  speed       Int    @default(30)

  characters  Character[]
}

model BackgroundDefinition {
  id          String @id @default(uuid()) @db.Uuid
  name        String @unique
  description String?

  characters  Character[]
}

model ClassFeatureDefinition {
  id               String @id @default(uuid()) @db.Uuid
  classId          String @db.Uuid

  name             String
  description      String?
  levelRequirement Int    @default(1)

  sectionType      FeatureSectionType @default(INFO)
  requiresInput    Boolean            @default(false)

  class            ClassDefinition @relation(fields: [classId], references: [id], onDelete: Cascade)
  selections       CharacterFeatureSelection[]
}

model CharacterFeatureSelection {
  id          String @id @default(uuid()) @db.Uuid
  characterId String @db.Uuid
  featureId   String @db.Uuid

  selectedValue String?
  customValue   String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  character     Character              @relation(fields: [characterId], references: [id], onDelete: Cascade)
  feature       ClassFeatureDefinition @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([characterId, featureId])
}

enum FeatureSectionType {
  INFO
  CHOICE
  TEXT_INPUT
  MULTI_CHOICE
}